CREATE TABLE tipo_usuario(
	tipo_usuario_id SERIAL PRIMARY KEY,
	nombre VARCHAR(50) NOT NULL,
	descripcion VARCHAR(100)
);

CREATE TABLE ciudad(
	ciudad_id SERIAL PRIMARY KEY,
	nombre VARCHAR(100) NOT NULL,
	codigo_postal INT
);

CREATE TABLE usuario(
	usuario_id SERIAL PRIMARY KEY,
	nombre VARCHAR(100) NOT NULL,
	apellido VARCHAR(100) NOT NULL,
	correo VARCHAR(100) UNIQUE,
	telefono VARCHAR(20),
	condicion_especial VARCHAR(100),
	
	tipo_usuario_id INT,
	ciudad_id INT,
	
	FOREIGN KEY (tipo_usuario_id) REFERENCES tipo_usuario(tipo_usuario_id),
	FOREIGN KEY (ciudad_id) REFERENCES ciudad(ciudad_id)
);

CREATE TABLE empleado(
	empleado_id SERIAL PRIMARY KEY,
	cargo VARCHAR(100),
	departamento VARCHAR(100),
	
	usuario_id INT UNIQUE,

	FOREIGN KEY (usuario_id) REFERENCES usuario(usuario_id)
);

CREATE TABLE servicio(
	servicio_id SERIAL PRIMARY KEY,
	nombre VARCHAR(100) NOT NULL,
	descripcion TEXT,
	estado VARCHAR(100)
);

CREATE TABLE turno(
	turno_id SERIAL PRIMARY KEY,
	fecha DATE,
	hora_inicio TIME,
	hora_fin TIME,
	estado VARCHAR (50),

	usuario_id INT,
	empleado_id INT,
	servicio_id INT,

	FOREIGN KEY (usuario_id) REFERENCES usuario(usuario_id),
	FOREIGN KEY (empleado_id) REFERENCES empleado(empleado_id),
	FOREIGN KEY (servicio_id) REFERENCES servicio(servicio_id)
);

CREATE TABLE medio(
	medio_id SERIAL PRIMARY KEY,
	nombre_medio VARCHAR(50)
);

CREATE TABLE notificacion(
	notificacion_id SERIAL PRIMARY KEY,
	mensaje TEXT,
	fecha_envio DATE,
	estado VARCHAR(50),

	usuario_id INT,
	medio_id INT,

	FOREIGN KEY (usuario_id) REFERENCES usuario(usuario_id),
	FOREIGN KEY (medio_id) REFERENCES medio(medio_id)
);